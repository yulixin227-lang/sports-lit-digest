# Required by NCBI if you run regular PubMed E-utilities jobs.
NCBI_EMAIL=your_email@example.com

# Optional. Raises PubMed rate limits if you have an NCBI API key.
NCBI_API_KEY=

# Optional but recommended for polite Crossref usage.
CROSSREF_MAILTO=your_email@example.com

# Optional. Semantic Scholar works without a key at lower rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# Pipeline switches.
ENABLE_CROSSREF=true
ENABLE_SEMANTIC_SCHOLAR=true
DIGEST_TIMEZONE=Asia/Taipei
PUBMED_RETMAX=100
DIGEST_MIN_SCORE=70
DIGEST_MAX_PAPERS=5
SKIP_EMPTY_PUSH=true

# Public digest URL. Leave empty to show the local HTML path in WeChat.
# GitHub Pages example:
# PUBLIC_DIGEST_BASE_URL=https://<your-github-username>.github.io/sports-lit-digest
# Cloudflare Pages or another static host also works if it serves outputs/*.html.
PUBLIC_DIGEST_BASE_URL=

# WeChat push via WxPusher. Default disabled; enable explicitly.
# Standard send supports either UID direct push or Topic subscription push.
# If WXPUSHER_APP_TOKEN + WXPUSHER_TOPIC_IDS are set, mentors can subscribe to the Topic and do not need to share UID.
WXPUSHER_SPT_ENABLED=false
WXPUSHER_SPT_URL=
WXPUSHER_ENABLED=false
WXPUSHER_APP_TOKEN=
WXPUSHER_UIDS=
WXPUSHER_TOPIC_IDS=

# Reserved fallback channel. Not implemented yet.
SERVERCHAN_ENABLED=false
SERVERCHAN_SENDKEY=
